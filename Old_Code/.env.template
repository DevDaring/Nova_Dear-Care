# Care Giver (Kelvin) - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# GEMINI API KEY (REQUIRED)
# ============================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Select project: hackathon-472817 (or your project)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# GCP PROJECT ID (Optional - for Google Cloud TTS/STT)
# ============================================================
# Only needed if using Google Cloud TTS/STT (not the free fallback)
# Your Google Cloud Platform project ID
GCP_PROJECT_ID=hackathon-472817

# ============================================================
# GOOGLE CLOUD CREDENTIALS (Optional)
# ============================================================
# For high-quality Google Cloud TTS/STT, set up service account:
# 1. Go to: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create service account with TTS/STT permissions
# 3. Download JSON key file
# 4. Set this path (or export GOOGLE_APPLICATION_CREDENTIALS in shell)
# 
# NOTE: If not set, the system uses FREE alternatives:
#   - TTS: gTTS (Google Text-to-Speech - free, no credentials)
#   - STT: SpeechRecognition library (Google free API)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# ============================================================
# BOSE BLUETOOTH SPEAKER SINK (Optional)
# ============================================================
# Find your Bose sink name with: pactl list short sinks
# Format: bluez_sink.<MAC_ADDRESS>.a2dp_sink
BOSE_SINK=bluez_sink.78_2B_64_DD_68_CF.a2dp_sink
