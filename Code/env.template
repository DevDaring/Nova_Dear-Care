# ============================================================
# Dear-Care - Environment Configuration Template
# Amazon Nova Hackathon | Voice AI Track
# ============================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_account_id
AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here

# AWS CodeCommit
CODECOMMIT_USER=your_codecommit_user
CODECOMMIT_PASSWORD=your_codecommit_password
CODECOMMIT_SSH_KEY_ID=your_ssh_key_id
SSH_PRIVATE_KEY_PATH=/home/sunrise/Documents/ssh/id_rsa

# S3 Configuration
S3_BUCKET_NAME=dear-care-data-your_account_id

# Audio Configuration
BOSE_SINK=bluez_sink.XX_XX_XX_XX_XX_XX.a2dp_sink

# Security
DEARCARE_PIN_HASH=

# Lambda
LAMBDA_FUNCTION_NAME=dear-care-clinical-notes

# ============================================================
# Fit-U Companion App Integration
# ============================================================
# API Gateway URL for Fit-U health data endpoint
FITU_API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# SNS Topic ARN for push notifications to Fit-U
FITU_SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:dear-care-fitu-notifications

# S3 prefix for Fit-U data
FITU_DATA_S3_PREFIX=fitu-companion/

# DynamoDB table for Fit-U health snapshots
FITU_DYNAMODB_TABLE=dear-care-fitu-health
